# PostgreSQL — consumed by the postgres container entrypoint
POSTGRES_DB=fcstreamtube
POSTGRES_USER=fcstreamtube
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Backend — consumed by the Spring Boot application
BACKEND_PORT=8080
# NOTE: "postgres" resolves only inside the Docker Compose network.
# For local development without Docker (./gradlew bootRun), change to localhost.
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/fcstreamtube
SPRING_DATASOURCE_USERNAME=fcstreamtube
SPRING_DATASOURCE_PASSWORD=changeme
